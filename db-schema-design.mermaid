---
title: GPU Gross Margin Visibility — Database Schema Design · 13 Tables · 8 Layers
---

erDiagram

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 0 — SESSION ANCHOR
    %%  One row = one ingestion session.
    %%  All 12 downstream tables carry session_id FK to this table.
    %%  This is the ONLY physical FK chain in the schema.
    %% ══════════════════════════════════════════════════════════════════════════════

    raw_ingestion_log {
        GUID        session_id   PK  "K1 — session anchor · carried through all 12 tables"
        NVARCHARMAX source_files     "JSON array of 5 source filenames · ISJSON validated"
        DATETIME2   ingested_at      "DEFAULT SYSUTCDATETIME"
        NVARCHAR20  status           "COMMITTED | FAILED"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 1 — RAW SOURCE TABLES (5 tables)
    %%  Role: FEEDS or CHECKS the grain.
    %%  raw.telemetry / raw.cost_management / raw.iam  → FEED grain (AE reads)
    %%  raw.billing / raw.erp                          → CHECK grain (RE Check 3 only)
    %% ══════════════════════════════════════════════════════════════════════════════

    raw_telemetry {
        BIGINT      id                  PK
        GUID        session_id          FK
        NVARCHAR100 region                  "grain dimension 1"
        NVARCHAR100 gpu_pool_id             "grain dimension 2"
        DATE        date                    "grain dimension 3 · ISO 8601 YYYY-MM-DD"
        NVARCHAR255 tenant_id               "unvalidated at ingestion · resolved to TypeA or IB by AE"
        DECIMAL18_6 gpu_hours_consumed      "gt 0 · multiple rows per grain cell valid (sub-interval metering)"
    }

    raw_cost_management {
        BIGINT      id                  PK
        GUID        session_id          FK  "UQ: (session_id, region, gpu_pool_id, date)"
        NVARCHAR100 region                  "grain dimension 1"
        NVARCHAR100 gpu_pool_id             "grain dimension 2"
        DATE        date                    "grain dimension 3"
        DECIMAL18_6 reserved_gpu_hours      "gt 0 · Closure Rule denominator"
        DECIMAL18_6 cost_per_gpu_hour       "gt 0 · flat rate per pool-day · copied to ALL grain rows"
    }

    raw_iam {
        BIGINT      id              PK
        GUID        session_id      FK  "UQ: (session_id, tenant_id, billing_period)"
        NVARCHAR255 tenant_id           "identity resolution key"
        NVARCHAR7   billing_period      "YYYY-MM · K2 cross-module contract · LEFT JOIN key for AE IAM Resolver"
        DECIMAL18_6 contracted_rate     "gte 0 · zero-rate tenants permitted (C-2) · TypeA revenue formula input"
    }

    raw_billing {
        BIGINT      id              PK
        GUID        session_id      FK  "UQ: (session_id, tenant_id, billing_period)"
        NVARCHAR255 tenant_id
        NVARCHAR7   billing_period      "YYYY-MM · Check 3 JOIN key"
        DECIMAL18_2 billable_amount     "sign scope: accepted risk R12-W-1 · compared to SUM(grain.revenue)"
    }

    raw_erp {
        BIGINT      id              PK
        GUID        session_id      FK  "UQ: (session_id, tenant_id, billing_period)"
        NVARCHAR255 tenant_id
        NVARCHAR7   billing_period      "YYYY-MM · Check 3 JOIN key"
        DECIMAL18_2 amount_posted       "sign scope: accepted risk R12-W-1 · compared to billing.billable_amount"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 2 — GRAIN TABLE (central source of truth)
    %%  One row = one grain cell: Region × GPU Pool × Day × Allocation Target
    %%  13 CHECK constraints · 3 filtered UNIQUE indexes (C-3)
    %%  INSTEAD OF UPDATE trigger (TR_allocation_grain_prevent_update · THROW 51003 · R14-W-1)
    %%  UPDATE-BLOCKED · DELETE permitted for Ingestion Commit session replacement
    %%  Producer: AE Allocation Grain Writer (C9) — INSERT-only · atomic · ROLLBACK on failure
    %% ══════════════════════════════════════════════════════════════════════════════

    dbo_allocation_grain {
        BIGINT      id                  PK
        GUID        session_id          FK
        NVARCHAR100 region                  "dimension 1"
        NVARCHAR100 gpu_pool_id             "dimension 2"
        DATE        date                    "dimension 3 · ISO 8601"
        NVARCHAR7   billing_period          "dimension 4a · LEFT(date,7) · K2 · K2 cross-module contract"
        NVARCHAR255 allocation_target       "dimension 4b · tenant_id (TypeA) | unallocated (TypeB)"
        NVARCHAR20  unallocated_type        "NULL (TypeA) | capacity_idle | identity_broken · case-sensitive P1#43"
        NVARCHAR255 failed_tenant_id        "NULL (TypeA+idle) · original tenant_id (IB only) · pass-through P1#10"
        DECIMAL18_6 gpu_hours               "gt 0 · consumed (TypeA+IB) or idle (capacity_idle)"
        DECIMAL18_6 cost_per_gpu_hour       "gt 0 · from raw_cost_management · same for all rows in pool-day"
        DECIMAL18_6 contracted_rate         "NULL (TypeB) · from raw_iam (TypeA only)"
        DECIMAL18_2 revenue                 "TypeA: hours x rate · TypeB: 0 always"
        DECIMAL18_2 cogs                    "gt 0 · hours x cost · all types"
        DECIMAL18_2 gross_margin            "TypeA: revenue-cogs · TypeB: -cogs (always lt 0)"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 3 — BOUNDARY INTEGRITY VERDICTS
    %%  One row = one check verdict for one session.
    %%  Exactly 3 rows per session (UQ on session_id + check_name).
    %%  Producer: RE Result Writer (C7) — atomic write: all 3 rows or none.
    %%  Consumer: UI Zone 3 — PASS/FAIL display only.
    %% ══════════════════════════════════════════════════════════════════════════════

    dbo_reconciliation_results {
        BIGINT      id              PK
        GUID        session_id      FK  "UQ: (session_id, check_name)"
        NVARCHAR50  check_name          "Capacity vs Usage | Usage vs Tenant Mapping | Computed vs Billed vs Posted"
        NVARCHAR4   verdict             "PASS | FAIL"
        NVARCHAR6   fail_subtype        "NULL | FAIL-1 | FAIL-2 · Check 3 FAIL only · required when Check 3 FAILs"
        INT         failing_count       "NULL on PASS · gt 0 on FAIL · operator diagnostic only · NOT surfaced to CFO"
        NVARCHARMAX detail              "operator diagnostic prose · format owned by C7 (R10-W-1) · NOT surfaced to CFO"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 4 — LIFECYCLE CONTROL (2 tables)
    %%  state_store:   current lifecycle state per session
    %%  state_history: append-only audit trail of every state transition
    %% ══════════════════════════════════════════════════════════════════════════════

    dbo_state_store {
        GUID        session_id          PK  "also FK → raw_ingestion_log · one row per session"
        NVARCHAR10  application_state       "EMPTY → UPLOADED → ANALYZED → APPROVED (terminal)"
        NVARCHAR10  session_status          "ACTIVE | TERMINAL · TERMINAL requires APPROVED"
        NVARCHAR10  analysis_status         "IDLE | ANALYZING · ANALYZING valid only during UPLOADED"
        NVARCHAR10  write_result            "NULL until APPROVED · SUCCESS | FAIL · Export Gate checks BOTH"
        INT         retry_count             "DEFAULT 0 · ceiling 100 · coupling warning if ANALYSIS_MAX_RETRIES gt 100"
    }

    dbo_state_history {
        BIGINT      id                  PK
        GUID        session_id          FK
        NVARCHAR10  from_state              "state enum: EMPTY | UPLOADED | ANALYZED | APPROVED"
        NVARCHAR10  to_state                "state enum: EMPTY | UPLOADED | ANALYZED | APPROVED"
        NVARCHAR50  transition_trigger      "7 enumerated: INGESTION_COMPLETE | ANALYSIS_DISPATCHED | ENGINES_COMPLETE | CFO_APPROVAL | ANALYSIS_FAILED | SESSION_CLOSED | SYSTEM_RECOVERY"
        DATETIME2   transitioned_at         "DEFAULT SYSUTCDATETIME · renamed from timestamp (R5-C-1)"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 5 — IMMUTABLE APPROVED RESULT
    %%  One row = one approved grain cell (verbatim copy of dbo_allocation_grain at APPROVED).
    %%  IMMUTABLE · INSTEAD OF UPDATE, DELETE trigger (TR_final_allocation_result_prevent_mutation · THROW 51000)
    %%  13 CHECK constraints (W-9 copy fidelity) · 3 filtered UNIQUE indexes (R7-W-1)
    %%  Producer: SM Approved Result Writer (C9) — single atomic transaction with APPROVED state write.
    %%  Consumer: Export Source Reader (all 3 export formats read ONLY this table).
    %% ══════════════════════════════════════════════════════════════════════════════

    final_allocation_result {
        BIGINT      id                  PK
        GUID        row_id              UK  "NEWSEQUENTIALID · per-row export traceability · prevents duplicate rows"
        GUID        session_id          FK
        DATETIME2   approved_at             "DEFAULT SYSUTCDATETIME · DB write time (W-11)"
        NVARCHAR100 region
        NVARCHAR100 gpu_pool_id
        DATE        date
        NVARCHAR7   billing_period
        NVARCHAR255 allocation_target
        NVARCHAR20  unallocated_type
        NVARCHAR255 failed_tenant_id        "pass-through P1#10 · NULL (TypeA+idle) · tenant_id (IB)"
        DECIMAL18_6 gpu_hours
        DECIMAL18_6 cost_per_gpu_hour
        DECIMAL18_6 contracted_rate
        DECIMAL18_2 revenue
        DECIMAL18_2 cogs
        DECIMAL18_2 gross_margin
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LAYER 6 — CACHE ARTIFACTS (2 tables)
    %%  Pre-computed at ANALYZED. Both IMMUTABLE per session_id after first write.
    %%  kpi_cache:                INSTEAD OF UPDATE, DELETE (TR_kpi_cache_prevent_mutation · THROW 51001 · R11-W-1)
    %%  identity_broken_tenants:  INSTEAD OF UPDATE, DELETE (TR_identity_broken_tenants_prevent_mutation · THROW 51002 · R11-W-2)
    %% ══════════════════════════════════════════════════════════════════════════════

    dbo_kpi_cache {
        GUID        session_id              PK  "also FK → raw_ingestion_log · one row per session"
        DECIMAL18_2 gpu_revenue                 "SUM(TypeA revenue) · gte 0 · Zone 1 KPI"
        DECIMAL18_2 gpu_cogs                    "SUM(TypeA cogs) · gte 0 · Zone 1 KPI"
        DECIMAL18_2 idle_gpu_cost               "SUM(TypeB cogs) · gte 0 · Zone 1 KPI"
        DECIMAL5_2  idle_gpu_cost_pct           "0–100 · complements cost_allocation_rate · tolerance 0.01"
        DECIMAL5_2  cost_allocation_rate        "0–100 · complements idle_gpu_cost_pct · tolerance 0.01"
        DATETIME2   computed_at                 "DEFAULT SYSUTCDATETIME · operator diagnostic timestamp"
    }

    dbo_identity_broken_tenants {
        GUID        session_id          PK  "composite PK col 1 · also FK → raw_ingestion_log"
        NVARCHAR255 failed_tenant_id    PK  "composite PK col 2 · Risk flag SET key · Zone 2R lookup"
    }

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  PHYSICAL FK RELATIONSHIPS
    %%  One chain: all 12 tables → raw_ingestion_log(session_id)
    %%  This is the ONLY physical FK in the schema.
    %%  No physical FKs between raw tables and dbo_allocation_grain (architecturally impossible:
    %%  capacity_idle rows have no raw.telemetry counterpart; GROUP BY breaks 1:1 mapping).
    %% ══════════════════════════════════════════════════════════════════════════════

    raw_ingestion_log ||--o{ raw_telemetry             : "session_id FK"
    raw_ingestion_log ||--o{ raw_cost_management       : "session_id FK"
    raw_ingestion_log ||--o{ raw_iam                   : "session_id FK"
    raw_ingestion_log ||--o{ raw_billing               : "session_id FK"
    raw_ingestion_log ||--o{ raw_erp                   : "session_id FK"
    raw_ingestion_log ||--o{ dbo_allocation_grain      : "session_id FK"
    raw_ingestion_log ||--o{ dbo_reconciliation_results: "session_id FK"
    raw_ingestion_log ||--|| dbo_state_store           : "session_id FK+PK · one-to-one"
    raw_ingestion_log ||--o{ dbo_state_history         : "session_id FK"
    raw_ingestion_log ||--o{ final_allocation_result   : "session_id FK"
    raw_ingestion_log ||--o| dbo_kpi_cache             : "session_id FK+PK · zero-or-one"
    raw_ingestion_log ||--o{ dbo_identity_broken_tenants: "session_id FK"

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  LOGICAL RELATIONSHIPS (application-layer — not physical FKs)
    %%  These are the coupling contracts that cross module boundaries.
    %%  Labeled with the join mechanism and the consuming component.
    %% ══════════════════════════════════════════════════════════════════════════════

    %% AE reads: raw sources → grain
    raw_telemetry       }o..o{ dbo_allocation_grain      : "GROUP BY tenant+pool+date · AE Telemetry Aggregator"
    raw_cost_management }o..o{ dbo_allocation_grain      : "lookup (pool, date) · AE Cost Rate Reader"
    raw_iam             }o..o{ dbo_allocation_grain      : "LEFT JOIN (tenant_id, billing_period) · AE IAM Resolver"

    %% RE reads: raw sources + grain → reconciliation verdicts
    raw_billing         }o..o{ dbo_reconciliation_results: "JOIN (tenant, period) · RE Check 3 FAIL-1"
    raw_erp             }o..o{ dbo_reconciliation_results: "JOIN (tenant, period) · RE Check 3 FAIL-2"
    dbo_allocation_grain}o..o{ dbo_reconciliation_results: "SUM(revenue) per allocation_target · RE Check 3"

    %% ANALYZED-time pre-computation: grain → cache artifacts
    dbo_allocation_grain ||..o| dbo_kpi_cache              : "aggregated at ANALYZED · KPI Data Aggregator"
    dbo_allocation_grain ||..o{ dbo_identity_broken_tenants: "IB SET built at ANALYZED · SET pre-builder"

    %% APPROVED copy: grain → immutable result
    dbo_allocation_grain ||..o{ final_allocation_result    : "copied verbatim at APPROVED · SM Result Writer C9"

    %% ══════════════════════════════════════════════════════════════════════════════
    %%  NATURAL KEY UNIQUE CONSTRAINTS (not shown as FK lines — enforced at DB level)
    %%
    %%  raw_cost_management:          UQ (session_id, region, gpu_pool_id, date)
    %%  raw_iam:                       UQ (session_id, tenant_id, billing_period)
    %%  raw_billing:                   UQ (session_id, tenant_id, billing_period)
    %%  raw_erp:                       UQ (session_id, tenant_id, billing_period)
    %%  dbo_reconciliation_results:    UQ (session_id, check_name)
    %%
    %%  dbo_allocation_grain — three filtered UNIQUE indexes (C-3):
    %%    UQ_grain_type_a_natural_key:            (session_id, region, gpu_pool_id, date, allocation_target)
    %%                                             WHERE allocation_target <> 'unallocated'
    %%    UQ_grain_capacity_idle_natural_key:     (session_id, region, gpu_pool_id, date, unallocated_type)
    %%                                             WHERE unallocated_type = 'capacity_idle'
    %%    UQ_grain_identity_broken_natural_key:   (session_id, region, gpu_pool_id, date, failed_tenant_id)
    %%                                             WHERE unallocated_type = 'identity_broken'
    %%
    %%  final_allocation_result — three filtered UNIQUE indexes mirroring grain (R7-W-1):
    %%    UQ_final_type_a_natural_key             (same predicate as grain TypeA index)
    %%    UQ_final_capacity_idle_natural_key      (same predicate as grain capacity_idle index)
    %%    UQ_final_identity_broken_natural_key    (same predicate as grain identity_broken index)
    %%
    %%  INSTEAD OF TRIGGER ERROR NUMBER REGISTRY:
    %%    THROW 51000 → TR_final_allocation_result_prevent_mutation   (final_allocation_result · Rounds 2/3)
    %%    THROW 51001 → TR_kpi_cache_prevent_mutation                 (dbo_kpi_cache · R11-W-1)
    %%    THROW 51002 → TR_identity_broken_tenants_prevent_mutation   (dbo_identity_broken_tenants · R11-W-2)
    %%    THROW 51003 → TR_allocation_grain_prevent_update            (dbo_allocation_grain · R14-W-1)
    %%    Next available: 51004
    %%
    %%  CROSS-MODULE COUPLING CONTRACTS (7):
    %%    K1  session_id YYYY-MM-DD — all 6 modules
    %%    K2  billing_period YYYY-MM — AE Deriver · IAM Resolver · RE Check 2 · RE Check 3
    %%    K3  failed_tenant_id — IB Builder → Calculator → Grain → IBT SET → Zone 2R Risk flag
    %%    K4  unallocated_type enum — Output Verifier Check 4 · Region pills · Export
    %%    K5  APPROVED + write_result atomic — C9 sole writer · Export Gate MUST check BOTH
    %%    K6  contracted_rate = 0 zero-rate UI — Zone 1 · Zone 2L · Zone 2R GM% guard
    %%    K7  EXPORT_COLUMN_ORDER — 13 grain columns only · infrastructure columns excluded
    %% ══════════════════════════════════════════════════════════════════════════════
