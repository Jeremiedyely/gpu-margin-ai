---
title: GPU Gross Margin Visibility — Data Flow · LR Architecture View · 4 Phase Gates
---

flowchart LR

    %% ══════════════════════════════════════════════════════════
    %%  PHASE 1 — INGEST
    %% ══════════════════════════════════════════════════════════

    subgraph P1["① INGEST"]
        direction TB
        IL(["raw.ingestion_log
        K1 session anchor
        COMMITTED | FAILED"])

        subgraph FEEDS["FEEDS grain"]
            T["raw.telemetry
            tenant × pool × day
            gpu_hours_consumed"]
            CM["raw.cost_management
            pool × day
            reserved_gpu_hours
            cost_per_gpu_hour"]
            IAM["raw.iam
            tenant × billing_period K2
            contracted_rate"]
        end

        subgraph CHECKS["CHECKS grain (RE only)"]
            BIL["raw.billing
            billable_amount
            ⚠ sign scope R12-W-1"]
            ERP["raw.erp
            amount_posted
            ⚠ sign scope R12-W-1"]
        end

        IL -->|"session_id FK × 5"| FEEDS
        IL -->|"session_id FK × 2"| CHECKS
    end

    %% ══════════════════════════════════════════════════════════
    %%  STATE MACHINE SPINE
    %% ══════════════════════════════════════════════════════════

    subgraph SM["⚙ STATE MACHINE · Lifecycle Spine"]
        direction TB
        G1{{"UPLOADED\ngate"}}
        G2{{"ANALYZED\ngate"}}
        G3{{"APPROVED\ngate"}}
        SS[["state_store
        application_state
        session_status
        write_result K5"]]
        SH[["state_history
        append-only audit
        7 transition triggers"]]
        G1 --> SS --> G2 --> SS
        SS --> G3
        SS -->|"every transition"| SH
    end

    %% ══════════════════════════════════════════════════════════
    %%  PHASE 2 — ANALYZE
    %% ══════════════════════════════════════════════════════════

    subgraph P2["② ANALYZE"]
        direction TB

        subgraph AE["ALLOCATION ENGINE"]
            AG[["dbo.allocation_grain
            ─────────────────────────
            Grain: Region × Pool × Day × Target
            TypeA: tenant rows · revenue + cogs
            TypeB: unallocated · −cogs only
            ─────────────────────────
            13 CHKs · 3 filtered UNIQUEs
            ⛔ UPDATE → THROW 51003
            INSERT-only · DELETE for replace"]]
        end

        subgraph PRE["PRE-COMPUTED at ANALYZED"]
            direction LR
            KC[["dbo.kpi_cache
            gpu_revenue
            gpu_cogs · idle_gpu_cost
            idle_gpu_cost_pct
            cost_allocation_rate
            ⛔ THROW 51001"]]

            IBT[["dbo.identity_broken_tenants
            session_id + failed_tenant_id
            IB SET · K3 · Zone 2R
            ⛔ THROW 51002"]]
        end

        subgraph RE["RECONCILIATION ENGINE"]
            RR[["dbo.reconciliation_results
            ─────────────────────────
            3 rows per session
            Check 1: Capacity vs Usage
            Check 2: Usage vs Tenant Mapping
            Check 3: Computed vs Billed vs Posted
            PASS | FAIL · FAIL-1 | FAIL-2"]]
        end

        AG -->|"SUM aggregate"| KC
        AG -->|"IB SET build"| IBT
    end

    %% ══════════════════════════════════════════════════════════
    %%  PHASE 3 — APPROVE
    %% ══════════════════════════════════════════════════════════

    subgraph P3["③ APPROVE · CFO Gate"]
        direction TB
        FAR[["final.allocation_result
        ─────────────────────────
        Verbatim copy of grain at APPROVED
        row_id NEWSEQUENTIALID
        approved_at  W-11
        ─────────────────────────
        13 CHKs W-9 · 3 UNIQUEs R7-W-1
        ⛔ UPDATE+DELETE → THROW 51000
        Sole writer: SM C9 · atomic"]]
    end

    %% ══════════════════════════════════════════════════════════
    %%  PHASE 4 — EXPORT
    %% ══════════════════════════════════════════════════════════

    subgraph P4["④ EXPORT"]
        direction TB
        EX["Export Source Reader
        ─────────────────────────
        CSV · Excel · ERP push
        Reads ONLY final.allocation_result
        K7: 13 grain columns only
        Gate: APPROVED + write_result=SUCCESS K5"]
    end

    %% ══════════════════════════════════════════════════════════
    %%  UI DISPLAY (read-only side layer)
    %% ══════════════════════════════════════════════════════════

    subgraph UI["🖥 UI · READ-ONLY at ANALYZED"]
        direction TB
        Z1["Zone 1
        KPI Summary
        gpu_revenue · gpu_cogs
        idle rate %"]
        Z2["Zone 2L + 2R
        Grain detail · GM%
        IB risk flag · K3"]
        Z3["Zone 3
        PASS/FAIL badges
        operator detail only"]
    end

    %% ══════════════════════════════════════════════════════════
    %%  PHASE GATE FLOWS
    %% ══════════════════════════════════════════════════════════

    P1      -->|"INGESTION_COMPLETE"| G1
    G1      -->|"ANALYSIS_DISPATCHED"| P2

    T       -->|"GROUP BY tenant+pool+date\nAE Telemetry Aggregator"| AG
    CM      -->|"cost_per_gpu_hour\nAE Cost Rate Reader"| AG
    IAM     -->|"LEFT JOIN tenant+period K2\ncontracted_rate"| AG

    AG      -->|"SUM revenue per target\nRE Check 3"| RR
    BIL     -->|"billable_amount\nCheck 3 FAIL-1"| RR
    ERP     -->|"amount_posted\nCheck 3 FAIL-2"| RR
    T       -->|"Check 1 + 2"| RR
    CM      -->|"reserved_gpu_hours\nCheck 1"| RR
    IAM     -->|"tenant set\nCheck 2"| RR

    P2      -->|"ENGINES_COMPLETE"| G2
    G2      -->|"CFO_APPROVAL"| P3

    AG      -->|"verbatim copy\nSM Result Writer C9\natomic transaction"| FAR

    G3      -->|"write_result K5\nExport Gate"| P4
    FAR     -->|"sole source\nall 3 formats"| EX

    KC      --> Z1
    AG      --> Z2
    IBT     --> Z2
    RR      --> Z3

    IL      -->|"session_id FK"| SS

    %% ══════════════════════════════════════════════════════════
    %%  STYLING
    %% ══════════════════════════════════════════════════════════

    classDef anchor  fill:#1e1b4b,stroke:#6366f1,color:#c7d2fe
    classDef raw     fill:#0c1a2e,stroke:#0ea5e9,color:#bae6fd
    classDef grain   fill:#052e1c,stroke:#10b981,color:#a7f3d0
    classDef recon   fill:#1c1100,stroke:#f59e0b,color:#fde68a
    classDef state   fill:#1f0a14,stroke:#ec4899,color:#fbcfe8
    classDef gate    fill:#2d1f3d,stroke:#d946ef,color:#f0abfc
    classDef final   fill:#1c0707,stroke:#ef4444,color:#fecaca
    classDef cache   fill:#150d2e,stroke:#a78bfa,color:#ddd6fe
    classDef ui      fill:#0f172a,stroke:#94a3b8,color:#e2e8f0
    classDef export  fill:#0f172a,stroke:#64748b,color:#cbd5e1

    class IL anchor
    class T,CM,IAM,BIL,ERP raw
    class AG grain
    class RR recon
    class SS,SH state
    class G1,G2,G3 gate
    class FAR final
    class KC,IBT cache
    class Z1,Z2,Z3 ui
    class EX export
